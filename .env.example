# --------------------------------------------
# PostgreSQL
# --------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:your_password@127.0.0.1:5432/anima

# --------------------------------------------
# Redis
# --------------------------------------------
REDIS_URL=redis://:your_password@127.0.0.1:6379/0

# --------------------------------------------
# MongoDB
# --------------------------------------------
MONGO_URL=mongodb://anima:your_password@127.0.0.1:27017
MONGO_DATABASE=anima

# --------------------------------------------
# Neo4j
# --------------------------------------------
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# --------------------------------------------
# CORS
# --------------------------------------------
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=false

# --------------------------------------------
# Auth
# --------------------------------------------
AUTH_TOKEN_SECRET=change_me
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800
